# Neon Postgres connection string
# Get from console.neon.tech → your project → Connection Details
# Use the unpooled connection for scripts/migrations; pooled for serverless
DATABASE_URL=postgresql://neondb_owner:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# OpenAI — used by the embedding script (server-only, never exposed to client)
OPENAI_API_KEY=sk-...

# Anthropic — used by the analysis layer (themes, tensions, digest, deepen, ask)
# Defer until you wire up analysis endpoints
ANTHROPIC_API_KEY=sk-ant-...
